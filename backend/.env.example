# Databricks SQL Warehouse connection (required for the Delta Lake loader feature)
# Get these from your Databricks workspace: SQL Warehouses → Connection details
DATABRICKS_HOST=your-workspace.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id
DATABRICKS_TOKEN=dapi...

# Unity Catalog location for FHIR tables (defaults below are used if not set)
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=fhir_ccda

# OpenRouter API key (required for narrative gap verification)
OPENROUTER_API_KEY=sk-or-v1-...
